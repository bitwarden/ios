{
    "manifest_version": 3,
    "name": "Bitwarden",
    "description": "Bitwarden Safari Web Extension",
    "version": "1.0",
    "background": {
        "scripts": ["background.js"]
    },
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "css": ["inline-popup.css"]
        }
    ],
    "permissions": [
        "nativeMessaging",
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ]
}
